---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout>
<!-- NAV -->
<nav>
  <div class="nav-in">
    <a class="logo-mark" href="#top" aria-label="Doodle Noodle Studio home">
      <img class="logo-light" src="https://res.cloudinary.com/dr8iorhci/image/upload/v1781264185/Doodle_Noodle_-_White_kxecg9.png" alt="Doodle Noodle Studio">
      <img class="logo-dark" src="https://res.cloudinary.com/dr8iorhci/image/upload/v1781264191/Doodle_Noodle_-_Black_cewox5.png" alt="Doodle Noodle Studio">
    </a>
    <button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <div class="nav-links" id="navLinks">
      <a href="#work">Our Work</a>
      <a href="#process">Process</a>
      <a href="#about">Team</a>
      <button class="theme-toggle" id="themeToggle" aria-label="Toggle light/dark mode" title="Toggle light mode">
        <span class="tt-body">
          <span class="tt-dial"></span>
          <span class="tt-mark on">ON</span>
          <span class="tt-mark off">OFF</span>
        </span>
      </button>
      <a class="nav-cta" href="#contact">Book a free call
        <span class="cta-dot"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2.5 6h7M6.5 3l3 3-3 3" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
    </div>
  </div>
</nav>

<!-- HERO -->
<header class="hero" id="top">
  <!-- scribble doodles replacing SVG scribbles -->
  <img class="hero-doodle hd1" src="https://res.cloudinary.com/dr8iorhci/image/upload/v1781272371/Artboard_2_copy_5_ht7xdb.png" alt="" aria-hidden="true">
  <img class="hero-doodle hd2" src="https://res.cloudinary.com/dr8iorhci/image/upload/v1781272372/Artboard_2_copy_4_xtypnk.png" alt="" aria-hidden="true">
  <img class="hero-doodle hd3" src="https://res.cloudinary.com/dr8iorhci/image/upload/v1781272371/Artboard_2_copy_2_zepxia.png" alt="" aria-hidden="true">
  <img class="hero-doodle hd4" src="https://res.cloudinary.com/dr8iorhci/image/upload/v1781272370/Artboard_2_copy_3_enbdc1.png" alt="" aria-hidden="true">

  <div class="wrap hero-top">
    <h1>Interview-style videos for businesses that want clients to <span class="hl">trust them</span> before they even call.</h1>
    <p class="hero-sub">Natural interview-style videos that make your business feel human, trustworthy, and professional. No fake scripts. No awkward acting. No cheesy ads. <span class="scribble" style="color:var(--cream)">Just real conversations.</span></p>
    <div class="hero-cta">
      <a class="btn btn-pri" href="#contact">Book a free discovery call
        <span class="btn-arrow"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 6h6M6.5 3.5L9 6l-2.5 2.5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <a class="btn btn-ghost" href="#work">See our work</a>
    </div>
  </div>

  <!-- hero video module: fanned 3 cards -->
  <div class="wrap">
    <div class="hero-cards">
      <div class="hc left">
        <video src="https://qtsfr6gyxrjtnqme.public.blob.vercel-storage.com/Video%208.mp4" muted loop playsinline preload="metadata"></video>
        <button class="hc-mute" aria-label="Toggle sound"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 6v4h2.5L9 13V3L5.5 6H3z" fill="#fff"/><path d="M11 6c.8.8.8 3.2 0 4" stroke="#fff" stroke-width="1.3" stroke-linecap="round"/></svg></button>
        <span class="hc-play-hint" aria-hidden="true"><img src="https://res.cloudinary.com/dr8iorhci/image/upload/v1781264183/Doodle_Noodle_-_Icon_kpxkim.png" alt=""></span>
      </div>
      <div class="hc center">
        <video src="https://qtsfr6gyxrjtnqme.public.blob.vercel-storage.com/reel%204%20wayne%20vers%202.mp4" muted loop playsinline preload="metadata"></video>
        <button class="hc-mute" aria-label="Toggle sound"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 6v4h2.5L9 13V3L5.5 6H3z" fill="#fff"/><path d="M11 6c.8.8.8 3.2 0 4" stroke="#fff" stroke-width="1.3" stroke-linecap="round"/></svg></button>
        <span class="hc-social ig" aria-hidden="true"><img src="https://res.cloudinary.com/dr8iorhci/image/upload/v1782802479/Instagram_logo_2022_oevaft.svg" alt="Instagram"></span>
        <span class="hc-social tt" aria-hidden="true"><img src="https://res.cloudinary.com/dr8iorhci/image/upload/v1782802518/Tiktok_icon_cv3eel.svg" alt="TikTok"></span>
        <span class="hc-play-hint" aria-hidden="true"><img src="https://res.cloudinary.com/dr8iorhci/image/upload/v1781264183/Doodle_Noodle_-_Icon_kpxkim.png" alt=""></span>
      </div>
      <div class="hc right">
        <video src="https://qtsfr6gyxrjtnqme.public.blob.vercel-storage.com/%D7%90%D7%99%D7%A0%D7%94%20%D7%A1%D7%A8%D7%98%D7%95%D7%9F%202.mp4" muted loop playsinline preload="metadata"></video>
        <button class="hc-mute" aria-label="Toggle sound"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 6v4h2.5L9 13V3L5.5 6H3z" fill="#fff"/><path d="M11 6c.8.8.8 3.2 0 4" stroke="#fff" stroke-width="1.3" stroke-linecap="round"/></svg></button>
        <span class="hc-play-hint" aria-hidden="true"><img src="https://res.cloudinary.com/dr8iorhci/image/upload/v1781264183/Doodle_Noodle_-_Icon_kpxkim.png" alt=""></span>
      </div>
    </div>
  </div>
</header>

<!-- HUMAN / PROBLEM -->
<section class="human sec-pad">
  <div class="wrap human-grid">
    <div class="rv">
      <span class="kicker">The problem</span>
      <h2 class="h2">You already know your business is good.</h2>
      <span class="scribble-note">…so why isn't the phone ringing?</span>
      <p style="margin-top:1.4rem">But the problem is simple: people don't know you yet. They don't know your story. They don't know how you work. They don't know why they should choose you instead of the next clinic, lawyer, realtor, beauty studio, or local business.</p>
      <p class="big">That's where we come in.</p>
      <div class="no-row">
        <span class="chip">no fake scripts</span>
        <span class="chip">no awkward acting</span>
        <span class="chip">no cheesy ads</span>
      </div>
      <p>Just real conversations, smart questions, beautiful filming, and videos that help people understand who you are.</p>
    </div>
    <div class="human-photos rv">
      <div class="ph"><img src="https://res.cloudinary.com/dr8iorhci/image/upload/v1781314833/DSC02169_jcf6cp.jpg" alt="On set with Doodle Noodle Studio" loading="lazy"></div>
      <div class="ph"><img src="https://res.cloudinary.com/dr8iorhci/image/upload/v1781314819/IMG_20230811_175711_ex0hsm.jpg" alt="Behind the scenes" loading="lazy"></div>
      <div class="ph"><img src="https://res.cloudinary.com/dr8iorhci/image/upload/v1781314628/IMG_2693_qklkuo.jpg" alt="Interview filming" loading="lazy"></div>
    </div>
  </div>
  <div class="wrap">
    <div class="sec-cta rv">
      <a class="btn btn-pri" href="#contact">Book a free discovery call
        <span class="btn-arrow"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 6h6M6.5 3.5L9 6l-2.5 2.5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <span class="trust-line"><span class="tdot"></span><b>No awkward acting</b> we guide the whole conversation</span>
    </div>
  </div>
</section>

<!-- BENEFITS / IMAGINE BENTO -->
<section class="benefits sec-pad">
  <div class="wrap">
    <div class="ben-head rv">
      <span class="kicker" style="justify-content:center">One filming day</span>
      <h2 class="h2">Imagine 10–15 videos from <span style="color:var(--orange-l)">one</span> filming day</h2>
      <p class="lead">Videos that answer your clients' real questions. Videos that show your personality. <span class="scribble" style="color:var(--cream)">Videos that make people feel like they already know you.</span></p>
    </div>

    <div class="bento">
      <!-- LEFT COLUMN: stats card -->
      <div class="bento-card b-stats rv" style="display:flex;flex-direction:column">
        <h3 class="bento-h">Content built to drive results that matter</h3>
        <div class="stat-pills">
          <span class="stat-pill"><svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M3 10L10 3M10 3H5M10 3V8" stroke="#F0305A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Avg watch time 32%</span>
          <span class="stat-pill"><svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M3 10L10 3M10 3H5M10 3V8" stroke="#F0305A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Engagement rate 45%</span>
        </div>
        <div class="bar-chart">
          <span class="bar-badge">10–15 videos</span>
          <div class="bar" style="height:30%"></div>
          <div class="bar" style="height:42%"></div>
          <div class="bar" style="height:55%"></div>
          <div class="bar" style="height:50%"></div>
          <div class="bar" style="height:68%"></div>
          <div class="bar" style="height:80%"></div>
          <div class="bar" style="height:100%"></div>
        </div>
      </div>

      <!-- MIDDLE-TOP: wide card with text only -->
      <div class="bento-card b-image rv" style="background:linear-gradient(135deg,var(--ink3) 0%,var(--ink2) 100%);display:flex;align-items:flex-end;padding:1.8rem">
        <div style="position:relative;z-index:2">
          <div class="bi-cap" style="position:static;font-size:clamp(1.6rem,3vw,2.6rem)">Professional, natural, human edits</div>
        </div>
      </div>

      <!-- LEFT COLUMN: revenue card -->
      <div class="bento-card b-rev rv">
        <span class="rev-ico"><svg width="22" height="22" viewBox="0 0 22 22" fill="none"><rect x="3" y="6" width="16" height="10" rx="2" stroke="#F5F0E8" stroke-width="1.5"/><circle cx="11" cy="11" r="2.5" stroke="#F5F0E8" stroke-width="1.5"/></svg></span>
        <span class="rev-num">1,000+</span>
        <span class="rev-lbl">Clients served abroad</span>
      </div>

      <!-- MIDDLE-BOTTOM: platforms card (spans 2 rows) -->
      <div class="bento-card b-platforms rv">
        <div class="plat-cloud">
          <span class="plat-ico" title="LinkedIn"><svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor"><path d="M4 6.5H1.5V15H4V6.5zM2.75 5.3a1.45 1.45 0 100-2.9 1.45 1.45 0 000 2.9zM16.5 15h-2.5v-4.2c0-1-.02-2.3-1.4-2.3s-1.6 1.1-1.6 2.2V15H8.5V6.5H11v1.16h.03c.35-.66 1.2-1.36 2.46-1.36 2.63 0 3.12 1.73 3.12 3.98V15z"/></svg></span>
          <span class="plat-ico" title="YouTube"><svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor"><path d="M16.5 5.6a1.9 1.9 0 00-1.35-1.35C13.95 4 9 4 9 4s-4.95 0-6.15.25A1.9 1.9 0 001.5 5.6 19.8 19.8 0 001.25 9c0 1.15.08 2.3.25 3.4a1.9 1.9 0 001.35 1.35C4.05 14 9 14 9 14s4.95 0 6.15-.25a1.9 1.9 0 001.35-1.35c.17-1.1.25-2.25.25-3.4s-.08-2.3-.25-3.4zM7.4 11.2V6.8L11.2 9l-3.8 2.2z"/></svg></span>
          <span class="plat-ico" title="Vimeo"><svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor"><path d="M16 5.6c-.07 1.55-1.15 3.68-3.24 6.37C10.6 14.78 8.8 16.2 7.34 16.2c-.9 0-1.67-.84-2.3-2.5-.42-1.55-.84-3.1-1.26-4.65-.47-1.66-.97-2.5-1.5-2.5-.12 0-.52.24-1.2.72L.32 6.3c.85-.75 1.7-1.5 2.53-2.25 1.15-1 2-1.52 2.6-1.58 1.4-.13 2.26.83 2.58 2.88.35 2.2.6 3.58.73 4.12.4 1.8.83 2.7 1.3 2.7.37 0 .92-.58 1.66-1.74.73-1.16 1.12-2.04 1.17-2.65.1-.92-.27-1.38-1.1-1.38-.4 0-.8.1-1.22.27.8-2.63 2.34-3.9 4.6-3.84 1.67.05 2.46 1.14 2.36 3.26z"/></svg></span>
          <span class="plat-ico" title="Instagram"><svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="3" y="3" width="12" height="12" rx="3.5" stroke="currentColor" stroke-width="1.5"/><circle cx="9" cy="9" r="3" stroke="currentColor" stroke-width="1.5"/><circle cx="12.8" cy="5.2" r="0.9" fill="currentColor"/></svg></span>
          <span class="plat-ico" title="Facebook"><svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor"><path d="M10.5 16v-6h2l.4-2.4h-2.4V6.1c0-.7.2-1.18 1.2-1.18h1.3V2.8c-.23-.03-1-.1-1.9-.1-1.9 0-3.2 1.16-3.2 3.28V7.6H5.6V10h2v6h2.9z"/></svg></span>
          <span class="plat-ico" title="TikTok"><svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor"><path d="M12 2.5c.3 2 1.8 3.2 3.6 3.3v2.5c-1.4 0-2.7-.45-3.6-1.2v5.6c0 2.5-2 4.5-4.5 4.5S3 15.2 3 12.7s2-4.5 4.5-4.5c.27 0 .53.02.78.07v2.6c-.25-.1-.5-.15-.78-.15-1.13 0-2 .9-2 2s.87 2 2 2 2-.9 2-2V2.5H12z"/></svg></span>
          <span class="plat-ico" title="Snapchat"><svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor"><path d="M9 2.5c1.9 0 3.2 1.5 3.2 3.4 0 .6 0 1.1.1 1.5.3.2.7.2 1 .1.5-.1.9.5.5.9-.3.3-1 .5-1.2.9-.2.6 1.3 2.4 2.6 2.7.3.1.3.5 0 .7-.5.3-1.4.3-1.7.7-.1.2 0 .6-.3.7-.4.1-1-.3-1.7-.1-.6.2-1.1 1-2.6 1s-2-.8-2.6-1c-.7-.2-1.3.2-1.7.1-.3-.1-.2-.5-.3-.7-.3-.4-1.2-.4-1.7-.7-.3-.2-.3-.6 0-.7 1.3-.3 2.8-2.1 2.6-2.7-.2-.4-.9-.6-1.2-.9-.4-.4 0-1 .5-.9.3.1.7.1 1-.1.1-.4.1-.9.1-1.5C5.8 4 7.1 2.5 9 2.5z"/></svg></span>
          <span class="plat-ico" title="YouTube Shorts"><svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor"><path d="M11.5 3.2L5.8 6.3c-1.5.8-1.9 2.6-1 4 .4.6 1 1 1.7 1.2l-.9.5c-1.5.8-1.9 2.6-1 4s2.7 1.7 4.1.9l5.7-3.1c1.5-.8 1.9-2.6 1-4-.4-.6-1-1-1.7-1.2l.9-.5c1.5-.8 1.9-2.6 1-4s-2.6-1.9-4.1-1.1zM7.5 11V7l3.5 2-3.5 2z"/></svg></span>
          <span class="plat-ico" title="X"><svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M9.5 7l4-5h-1.2L9 5.9 6.3 2H3l4.2 6L3 14h1.2L8 9.7l3 4.3h3.3L9.5 7zm-1.3 1.5l-.5-.6L4.5 3h1.4l3 4.3.5.6 3.6 5.1h-1.4L8.2 8.5z"/></svg></span>
        </div>
        <h3>Optimized for every platform, every format</h3>
        <p>Every video is adapted to fit the platform, format, and audience it's made for.</p>
      </div>
      <!-- RIGHT col: direction card -->
      <div class="bento-card b-quick rv">
        <h3>Natural direction on camera</h3>
        <p>You don't memorize anything we guide you so every answer feels natural.</p>
        <div class="clock" aria-hidden="true"></div>
      </div>
    </div>
  </div>
  <div class="wrap">
    <div class="sec-cta rv">
      <a class="btn btn-pri" href="#contact">Book a free discovery call
        <span class="btn-arrow"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 6h6M6.5 3.5L9 6l-2.5 2.5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <span class="trust-line"><span class="tdot"></span><b>One filming day</b> → weeks of content for every platform</span>
    </div>
  </div>
</section>

<!-- WORK -->
<section class="work sec-pad" id="work">
  <div class="wrap">
    <div class="work-head">
      <div class="rv">
        <span class="kicker">Our work</span>
        <h2 class="h2">Real businesses.<br>Real conversations.</h2>
      </div>
    </div>
        <div class="work-grid">
      <article class="proj rv" data-src="https://qtsfr6gyxrjtnqme.public.blob.vercel-storage.com/reel%204%20wayne%20vers%202.mp4">
        <video src="https://qtsfr6gyxrjtnqme.public.blob.vercel-storage.com/reel%204%20wayne%20vers%202.mp4" muted loop playsinline preload="metadata"></video>
        <span class="proj-tag">Interview</span>
        <span class="proj-play-hint" aria-hidden="true"><img src="https://res.cloudinary.com/dr8iorhci/image/upload/v1781264183/Doodle_Noodle_-_Icon_kpxkim.png" alt=""></span>
      </article>
      <article class="proj rv" data-src="https://qtsfr6gyxrjtnqme.public.blob.vercel-storage.com/Video%202%20daniel%20.mp4">
        <video src="https://qtsfr6gyxrjtnqme.public.blob.vercel-storage.com/Video%202%20daniel%20.mp4" muted loop playsinline preload="metadata"></video>
        <span class="proj-tag">Founder story</span>
        <span class="proj-play-hint" aria-hidden="true"><img src="https://res.cloudinary.com/dr8iorhci/image/upload/v1781264183/Doodle_Noodle_-_Icon_kpxkim.png" alt=""></span>
      </article>
      <article class="proj rv" data-src="https://qtsfr6gyxrjtnqme.public.blob.vercel-storage.com/Video%208.mp4">
        <video src="https://qtsfr6gyxrjtnqme.public.blob.vercel-storage.com/Video%208.mp4" muted loop playsinline preload="metadata"></video>
        <span class="proj-tag">Client</span>
        <span class="proj-play-hint" aria-hidden="true"><img src="https://res.cloudinary.com/dr8iorhci/image/upload/v1781264183/Doodle_Noodle_-_Icon_kpxkim.png" alt=""></span>
      </article>
      <article class="proj rv" data-src="https://qtsfr6gyxrjtnqme.public.blob.vercel-storage.com/%D7%90%D7%99%D7%A0%D7%94%20%D7%A1%D7%A8%D7%98%D7%95%D7%9F%202.mp4">
        <video src="https://qtsfr6gyxrjtnqme.public.blob.vercel-storage.com/%D7%90%D7%99%D7%A0%D7%94%20%D7%A1%D7%A8%D7%98%D7%95%D7%9F%202.mp4" muted loop playsinline preload="metadata"></video>
        <span class="proj-tag">Brand</span>
        <span class="proj-play-hint" aria-hidden="true"><img src="https://res.cloudinary.com/dr8iorhci/image/upload/v1781264183/Doodle_Noodle_-_Icon_kpxkim.png" alt=""></span>
      </article>
      <article class="proj rv" data-src="https://qtsfr6gyxrjtnqme.public.blob.vercel-storage.com/%D7%A7%D7%9E%D7%A4%D7%99%D7%99%D7%9F%20-%D7%90%D7%A8%D7%99%D7%90%D7%9C%D7%94%20%D7%A1%D7%A8%D7%98%D7%95%D7%9F%209%20%D7%92%D7%A8%D7%A1%D7%94%20%D7%92%20%281%29.mp4">
        <video src="https://qtsfr6gyxrjtnqme.public.blob.vercel-storage.com/%D7%A7%D7%9E%D7%A4%D7%99%D7%99%D7%9F%20-%D7%90%D7%A8%D7%99%D7%90%D7%9C%D7%94%20%D7%A1%D7%A8%D7%98%D7%95%D7%9F%209%20%D7%92%D7%A8%D7%A1%D7%94%20%D7%92%20%281%29.mp4" muted loop playsinline preload="metadata"></video>
        <span class="proj-tag">Campaign</span>
        <span class="proj-play-hint" aria-hidden="true"><img src="https://res.cloudinary.com/dr8iorhci/image/upload/v1781264183/Doodle_Noodle_-_Icon_kpxkim.png" alt=""></span>
      </article>
      <article class="proj rv" data-src="https://qtsfr6gyxrjtnqme.public.blob.vercel-storage.com/reel%209%20wayne.mp4">
        <video src="https://qtsfr6gyxrjtnqme.public.blob.vercel-storage.com/reel%209%20wayne.mp4" muted loop playsinline preload="metadata"></video>
        <span class="proj-tag">Short-form</span>
        <span class="proj-play-hint" aria-hidden="true"><img src="https://res.cloudinary.com/dr8iorhci/image/upload/v1781264183/Doodle_Noodle_-_Icon_kpxkim.png" alt=""></span>
      </article>
    </div>
  </div>
  <div class="wrap">
    <div class="sec-cta rv">
      <a class="btn btn-pri" href="#contact">Book a free discovery call
        <span class="btn-arrow"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 6h6M6.5 3.5L9 6l-2.5 2.5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </a>
      <span class="trust-line"><span class="tdot"></span>Real businesses, <b>real results</b> see yourself here next</span>
    </div>
  </div>
</section>

<!-- PROCESS -->
<section class="process sec-pad" id="process">
  <div class="wrap">
    <div class="proc-head rv">
      <span class="kicker" style="justify-content:center">How it works</span>
