<script is:inline>
// ── LIGHTBOX ──────────────────────────────────────────────────────────────
const lb        = document.getElementById('lb');
const lbVideo   = document.getElementById('lbVideo');
const lbClose   = document.getElementById('lbClose');
const lbSound   = document.getElementById('lbSound');
const lbPrev    = document.getElementById('lbPrev');
const lbNext    = document.getElementById('lbNext');
const lbCounter = document.getElementById('lbCounter');

let allSrcs = [];
let currentIdx = 0;
let isMuted = false;

function openLb(idx) {
  currentIdx = ((idx % allSrcs.length) + allSrcs.length) % allSrcs.length;
  lbVideo.src = allSrcs[currentIdx];
  lbVideo.muted = isMuted;
  lbVideo.load();
  lbVideo.play().catch(() => { lbVideo.muted = true; isMuted = true; updateSoundIcon(); lbVideo.play(); });
  lbCounter.textContent = (currentIdx + 1) + ' / ' + allSrcs.length;
  lb.classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeLb() {
  lb.classList.remove('open');
  lbVideo.pause();
  lbVideo.removeAttribute('src');
  lbVideo.load();
  document.body.style.overflow = '';
}

function navLb(dir) {
  openLb(currentIdx + dir);
}

function updateSoundIcon() {
  lbSound.innerHTML = isMuted
    ? '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 6v4h2.5L9 13V3L5.5 6H3z" fill="#fff"/><line x1="11" y1="6" x2="15" y2="10" stroke="#fff" stroke-width="1.3" stroke-linecap="round"/><line x1="15" y1="6" x2="11" y2="10" stroke="#fff" stroke-width="1.3" stroke-linecap="round"/></svg>'
    : '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 6v4h2.5L9 13V3L5.5 6H3z" fill="#fff"/><path d="M11 6c.8.8.8 3.2 0 4" stroke="#fff" stroke-width="1.3" stroke-linecap="round"/></svg>';
}

lbClose.addEventListener('click', closeLb);
lb.addEventListener('click', (e) => { if (e.target === lb) closeLb(); });
lbPrev.addEventListener('click', () => navLb(-1));
lbNext.addEventListener('click', () => navLb(1));
lbSound.addEventListener('click', () => {
  isMuted = !isMuted;
  lbVideo.muted = isMuted;
  updateSoundIcon();
});
document.addEventListener('keydown', (e) => {
  if (!lb.classList.contains('open')) return;
  if (e.key === 'Escape')      closeLb();
  if (e.key === 'ArrowRight')  navLb(1);
  if (e.key === 'ArrowLeft')   navLb(-1);
});

// ── Build the master video list from DOM (raw attribute, not resolved .src) ─
function buildSrcs() {
  const heroVids = [...document.querySelectorAll('.hc video')]
    .map(v => v.getAttribute('src')).filter(Boolean);
  const gridVids = [...document.querySelectorAll('.proj[data-src]')]
    .map(c => c.dataset.src);
  return heroVids.concat(gridVids);
}

// ── HERO CARDS — click to open lightbox ─────────────────────────────────────
document.querySelectorAll('.hc').forEach((card, i) => {
  card.style.cursor = 'pointer';
  card.addEventListener('click', (e) => {
    if (e.target.closest('.hc-mute')) return;
    allSrcs = buildSrcs();
    openLb(i);
  });
});

// ── GRID CARDS — click to open lightbox ─────────────────────────────────────
document.querySelectorAll('.proj[data-src]').forEach((card, i) => {
  card.addEventListener('click', (e) => {
    if (e.target.closest('.proj-mute')) return;
    allSrcs = buildSrcs();
    const heroCount = document.querySelectorAll('.hc video').length;
    openLb(heroCount + i);
  });
});

// ── MUTE BUTTONS (grid preview only — stops propagation so no lightbox) ──
function bindMute(btn) {
  const card = btn.closest('.proj') || btn.closest('.hc');
  const v = card ? card.querySelector('video') : null;
  if (!v) return;
  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    v.muted = !v.muted;
    if (!v.muted) v.play().catch(() => {});
  });
}
document.querySelectorAll('.hc-mute').forEach(bindMute);

// ── HAMBURGER MENU ─────────────────────────────────────────────────────────
const hamburger = document.getElementById('hamburger');
const fsMenu    = document.getElementById('fsMenu');
const fsClose   = document.getElementById('fsClose');

function openFsMenu() {
  fsMenu.classList.add('open');
  hamburger.classList.add('open');
  hamburger.setAttribute('aria-expanded', 'true');
  document.body.style.overflow = 'hidden';
}
function closeFsMenu() {
  fsMenu.classList.remove('open');
  hamburger.classList.remove('open');
  hamburger.setAttribute('aria-expanded', 'false');
  document.body.style.overflow = '';
}
hamburger?.addEventListener('click', () => {
  fsMenu.classList.contains('open') ? closeFsMenu() : openFsMenu();
});
fsClose?.addEventListener('click', closeFsMenu);
document.addEventListener('keydown', e => {
  if (e.key === 'Escape' && fsMenu.classList.contains('open')) closeFsMenu();
});


(function(){
  const nav  = document.querySelector('nav');
  const work = document.getElementById('work');
  if (!nav || !work) return;

  function isMobileGrid() {
    return window.matchMedia('(max-width:820px)').matches;
  }

  const workObs = new IntersectionObserver(entries => {
    if (!isMobileGrid()) return;
    entries.forEach(e => {
      if (e.isIntersecting) {
        nav.style.transition = 'opacity .35s, transform .35s';
        nav.style.opacity    = '0';
        nav.style.transform  = 'translateX(-50%) scale(.96) translateY(-12px)';
        nav.style.pointerEvents = 'none';
      } else {
        nav.style.opacity    = '1';
        nav.style.transform  = 'translateX(-50%) scale(.96)';
        nav.style.pointerEvents = '';
      }
    });
  }, { threshold: 0.15 });

  workObs.observe(work);

  // reset on desktop resize
  window.addEventListener('resize', () => {
    if (!isMobileGrid()) {
      nav.style.opacity = '1';
      nav.style.transform = 'translateX(-50%) scale(.96)';
      nav.style.pointerEvents = '';
    }
  });
})();

const io = new IntersectionObserver(es => {
  es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
}, { threshold: .12 });
document.querySelectorAll('.rv').forEach(el => io.observe(el));

// ── AUTOPLAY VIDEOS IN VIEW ────────────────────────────────────────────────
const vObs = new IntersectionObserver(es => {
  es.forEach(e => {
    const v = e.target;
    if (e.isIntersecting) v.play().catch(() => {});
    else v.pause();
  });
}, { threshold: .25 });
document.querySelectorAll('video').forEach(v => vObs.observe(v));

// ── DSLR THEME TOGGLE ─────────────────────────────────────────────────────
const toggle = document.getElementById('themeToggle');
const toggleMobile = document.getElementById('themeToggleMobile');
const root   = document.documentElement;
if (localStorage.getItem('theme') === 'light') root.setAttribute('data-theme', 'light');

function applyTheme(isLight) {
  root[isLight ? 'setAttribute' : 'removeAttribute']('data-theme', 'light');
  localStorage.setItem('theme', isLight ? 'light' : 'dark');
}

toggle.addEventListener('click', () => applyTheme(root.getAttribute('data-theme') !== 'light'));
toggleMobile?.addEventListener('click', () => applyTheme(root.getAttribute('data-theme') !== 'light'));

</script>
