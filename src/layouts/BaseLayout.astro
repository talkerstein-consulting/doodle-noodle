---
import '../styles/global.css';

const {
  title = 'Doodle Noodle Studio | Interview Videos for Toronto Businesses',
  description = 'Interview-style brand videos for Toronto businesses that want clients to know, trust, and choose them before they even call.',
  canonicalUrl = 'https://doodlenoodleca.com/',
  image = 'https://res.cloudinary.com/dr8iorhci/image/upload/c_fill,w_1200,h_630,g_auto,q_auto,f_auto/v1781314833/DSC02169_jcf6cp.jpg',
  imageAlt = 'Doodle Noodle Studio filming interview-style brand videos on set',
} = Astro.props;

const gaId = import.meta.env.PUBLIC_GA_ID || 'G-CK9SB0ZMYP';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {gaId && <script async is:inline src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>}
    {gaId && (
      <script is:inline define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    )}
    <title>{title}</title>
    <link rel="icon" type="image/png" href="https://res.cloudinary.com/dr8iorhci/image/upload/v1781264183/Doodle_Noodle_-_Icon_kpxkim.png" />
    <link rel="shortcut icon" type="image/png" href="https://res.cloudinary.com/dr8iorhci/image/upload/v1781264183/Doodle_Noodle_-_Icon_kpxkim.png" />
    <link rel="apple-touch-icon" href="https://res.cloudinary.com/dr8iorhci/image/upload/v1781264183/Doodle_Noodle_-_Icon_kpxkim.png" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Doodle Noodle Studio" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:secure_url" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700;800&family=Shantell+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>
